outputs:
  default:
    type: elasticsearch
    hosts:
      - "http://10.10.1.1:9200"
    username: "elastic"
    password: "vagrant"

inputs:
  - type: winlog
    streams:
      - name: Microsoft-Windows-Sysmon/Operational
        data_stream:
          dataset: windows.sysmon_operational
          type: logs
        ignore_older: 72h
